{
  "schema_version": "1.0",
  "site_id": "metime-to",
  "brand_name": "metime.to",
  "contact_email": "founders@metime.to",
  "locale_defaults": {
    "speech_modes": ["hindi", "hinglish"],
    "default_speech_mode": "hinglish",
    "target_output_language": "en"
  },
  "audio_eval_consent": true,
  "audio_eval_notice": "metime.to allows recordings to be used to improve this demo. Do not share sensitive information.",
  "retention": {
    "retain_raw_audio_for_eval": true,
    "retain_transcript_for_eval": true,
    "retain_generated_message_for_eval": true,
    "default_for_future_end_users": false
  },
  "design_tokens": {
    "font_family": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
    "color_background": "#fbfaff",
    "color_surface": "#ffffff",
    "color_surface_subtle": "#f4f0ff",
    "color_text": "#171321",
    "color_text_muted": "#6d6478",
    "color_primary": "#6d4aff",
    "color_primary_hover": "#5637df",
    "color_accent": "#20c7a7",
    "color_accent_soft": "#dffaf4",
    "color_border": "#ded6f2",
    "color_danger": "#c2415d",
    "shadow_soft": "0 18px 48px rgba(51, 35, 96, 0.16)",
    "radius_container": "18px",
    "radius_control": "12px",
    "radius_button": "14px",
    "space_1": "4px",
    "space_2": "8px",
    "space_3": "12px",
    "space_4": "16px",
    "space_5": "24px",
    "space_6": "32px"
  },
  "copy": {
    "heading": "Tell us what you need",
    "subheading": "Speak in Hindi or Hinglish. We will draft an English message.",
    "record_cta": "Record message",
    "stop_cta": "Stop recording",
    "send_cta": "Send message",
    "success": "Message sent. Thanks. The team will get back to you."
  }
}
