# Voice Reach V1 local Modal runtime profile.
# This file is non-secret. The app auto-loads APP_MODAL_BASE_URL and
# APP_MODAL_AUTH_TOKEN from product/5-idea-voice-contact-widget/.env.modal.local.
#
# To run locally against Modal later, source/export these values before starting
# the Space app. Do not run Modal serve/deploy just to use this profile.

VCW_MODEL_MODE=real
VCW_MODEL_RUNTIME=modal
VCW_ALLOW_RUNTIME_SWITCH=1
APP_MODAL_TIMEOUT_SECONDS=180
APP_MODAL_MODEL_ID=CohereLabs/tiny-aya-fire-GGUF
APP_MODAL_ASR_MODEL_ID=nvidia/nemotron-3.5-asr-streaming-0.6b
